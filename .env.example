BRAWL_API_TOKEN=replace_with_your_brawl_stars_api_token
BRAWL_CLUB_TAG=#2L9R0QPLQ
BRAWL_CLUB_NAME=The Hive
COMPETITION_TIME_ZONE=America/Guatemala

# Optional: protects POST /api/snapshot when the site is deployed.
SNAPSHOT_SECRET=make_a_long_random_secret

# Vercel Cron uses CRON_SECRET automatically as an Authorization bearer token.
CRON_SECRET=make_a_long_random_secret

# Optional: push local snapshots into production from an allowlisted IP.
SNAPSHOT_IMPORT_URL=https://www.the-hive.club/api/snapshot/import

# For Vercel deployment persistence, create a private Vercel Blob store.
# Vercel will inject BLOB_READ_WRITE_TOKEN or BLOB_STORE_ID + VERCEL_OIDC_TOKEN.
BLOB_ACCESS=private
